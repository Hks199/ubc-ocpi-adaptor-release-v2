{
    "name": "ubc-ocpi-adaptor",
    "version": "1.0.0",
    "description": "EMSP OCPI server that integrates with CPO systems and syncs to CDS for UBC protocol",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc",
        "start": "node dist/index.js",
        "dev": "tsx watch src/index.ts",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "lint": "eslint src --ext .ts",
        "lint:fix": "eslint src --ext .ts --fix",
        "format": "node scripts/fix-braces.js",
        "format:check": "echo \"Prettier disabled\"",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate dev",
        "prisma:migrate:deploy": "prisma migrate deploy",
        "prisma:studio": "prisma studio",
        "init-db": "bash scripts/init-db.sh",
        "healthcheck": "bash scripts/healthcheck.sh"
    },
    "keywords": [
        "ocpi",
        "ev-charging",
        "emsp",
        "ubc"
    ],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@prisma/client": "^6.19.0",
        "@types/node-cron": "^3.0.11",
        "axios": "1.7.7",
        "cors": "2.8.5",
        "dotenv": "16.4.5",
        "express": "4.21.0",
        "ioredis": "5.4.1",
        "jose": "6.1.3",
        "jsonwebtoken": "9.0.2",
        "libsodium-wrappers": "0.7.15",
        "lodash": "^4.17.21",
        "node-cron": "^4.2.1",
        "uuid": "10.0.0",
        "winston": "3.15.0",
        "zod": "3.23.8"
    },
    "devDependencies": {
        "@types/cors": "2.8.17",
        "@types/express": "5.0.0",
        "@types/jsonwebtoken": "9.0.6",
        "@types/libsodium-wrappers": "0.7.14",
        "@types/lodash": "^4.17.21",
        "@types/node": "22.7.5",
        "@types/uuid": "10.0.0",
        "@typescript-eslint/eslint-plugin": "8.0.0",
        "@typescript-eslint/parser": "8.0.0",
        "eslint": "9.12.0",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-prettier": "5.5.4",
        "globals": "16.5.0",
        "jest": "29.7.0",
        "prettier": "3.7.2",
        "prisma": "^6.19.0",
        "ts-jest": "29.2.5",
        "tsx": "4.19.1",
        "typescript": "5.6.2"
    },
    "engines": {
        "node": ">=22.0.0"
    }
}
