// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// OCPI 2.2.1 Location Model
model Location {
  id                   String    @id @default(uuid())
  ocpi_location_id     String // OCPI ID sent by CPO
  name                 String?
  latitude             String // From coordinates
  longitude            String // From coordinates
  country_code         String
  party_id             String
  city                 String
  postal_code          String?
  state                String?
  country              String
  address              String
  time_zone            String
  parking_type         String? // OCPIParkingType enum
  related_locations    Json? // OCPIAdditionalGeoLocation[]
  directions           Json? // OCPIDisplayText[]
  operator             Json? // OCPIBusinessDetailsClass
  suboperator          Json? // OCPIBusinessDetailsClass
  owner                Json? // OCPIBusinessDetailsClass
  facilities           String[] // OCPIFacility[]
  opening_times        Json? // OCPIHours
  images               Json? // OCPIImageClass[]
  energy_mix           Json? // OCPIEnergyMix
  charging_when_closed Boolean?
  publish              Boolean   @default(false)
  publish_allowed_to   Json? // OCPIPublishTokenType[]
  last_updated         DateTime
  deleted              Boolean   @default(false)
  deleted_at           DateTime?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt
  external_object_id   String    @unique 

  // Relations
  evses      EVSE[]
  partner_id String
  partner    OCPIPartner @relation(fields: [partner_id], references: [id], onDelete: Cascade)
  ocpilogs   OCPILog[]

  @@unique([country_code, party_id, ocpi_location_id])
  // Optimizes lookups by OCPI location id scoped to partner
  @@index([ocpi_location_id, partner_id])
  @@index([partner_id])
  @@map("location")
}

// OCPI 2.2.1 EVSE Model
model EVSE {
  id                      String    @id @default(uuid())
  location_id             String
  location                Location  @relation(fields: [location_id], references: [id], onDelete: Cascade)
  uid                     String // OCPI ID sent by CPO
  evse_id                 String?
  status                  String // OCPIStatus enum
  status_schedule         Json? // OCPIStatusSchedule[]
  capabilities            String[] // OCPICapability[]
  floor_level             String?
  latitude                String? // From coordinates
  longitude               String? // From coordinates
  physical_reference      String?
  directions              Json? // OCPIDisplayText[]
  parking_restrictions    String[] // OCPIParkingRestriction[]
  images                  Json? // OCPIImageClass[]
  status_errorcode        String?
  status_errordescription String?
  last_updated            DateTime
  deleted                 Boolean   @default(false)
  deleted_at              DateTime?
  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt
  partner_id              String
  external_object_id      String    @unique 

  // Relations
  evse_connectors EVSEConnector[]
  partner         OCPIPartner     @relation(fields: [partner_id], references: [id], onDelete: Cascade)
  ocpilogs        OCPILog[]

  @@unique([location_id, uid])
  @@index([location_id])
  @@map("evse")
}

// OCPI 2.2.1 Connector Model
model EVSEConnector {
  id                   String      @id @default(uuid())
  evse_id              String
  evse                 EVSE        @relation(fields: [evse_id], references: [id], onDelete: Cascade)
  connector_id         String // OCPI ID sent by CPO
  standard             String // OCPIConnectorType enum
  format               String // OCPIConnectorFormat enum
  qr_code              String?
  power_type           String // OCPIPowerType enum
  max_voltage          BigInt
  max_amperage         BigInt
  max_electric_power   BigInt?
  terms_and_conditions String? // URL
  last_updated         DateTime
  deleted              Boolean     @default(false)
  deleted_at           DateTime?
  created_at           DateTime    @default(now())
  updated_at           DateTime    @updatedAt
  tariff_ids           String[]
  tariffs              Tariff[]
  partner_id           String
  partner              OCPIPartner @relation(fields: [partner_id], references: [id], onDelete: Cascade)
  ocpilogs             OCPILog[]
  beckn_connector_id   String      @unique // Beckn connector ID (format: IND*TPC*{ocpi_location_id}*{evse_uid}*{connector_id}). If provided, only this connector will be published.
  ubc_catalog_id       String?     /// the catalog id used during published the cpc
  ubc_publish_enabled  String?     @default("true")  /// Determines if a cpc should be published or not
  ubc_publish_info     Json?       @default("{}") @db.Json /// Information about the publication of the cpc like last published_at, published, etc.


  @@unique([evse_id, connector_id])
  @@index([evse_id])
  // Optimizes getByConnectorId lookups
  @@index([connector_id])
  @@index([partner_id])
  @@index([beckn_connector_id])
  @@map("evse_connector")
}

// OCPI 2.2.1 Tariff Model
model Tariff {
  id                  String         @id @default(uuid())
  country_code        String
  party_id            String
  ocpi_tariff_id      String // OCPI ID sent by CPO
  currency            String
  type                String? // OCPITariffType enum
  tariff_alt_text     Json? // OCPIDisplayText[]
  tariff_alt_url      String? // URL
  min_price           Json? // OCPIPrice
  max_price           Json? // OCPIPrice
  start_date_time     DateTime?
  end_date_time       DateTime?
  energy_mix          Json? // OCPIEnergyMix
  last_updated        DateTime
  created_at          DateTime       @default(now())
  updated_at          DateTime       @updatedAt
  ocpi_tariff_element Json?
  evseconnector       EVSEConnector? @relation(fields: [eVSEConnectorId], references: [id], onDelete: Cascade)
  eVSEConnectorId     String?
  partner_id          String
  partner             OCPIPartner    @relation(fields: [partner_id], references: [id], onDelete: Cascade)

  @@unique([country_code, party_id, ocpi_tariff_id])
  @@index([country_code, party_id])
  @@index([ocpi_tariff_id])
  // Optimizes partner-scoped tariff queries
  @@index([partner_id, country_code, party_id])
  @@index([partner_id])
  @@map("tariff")
}

