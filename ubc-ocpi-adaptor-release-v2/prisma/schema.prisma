// OCPI 2.2.1 Session Model
model Session {
  id                                String       @id @default(uuid())
  country_code                      String?
  party_id                          String?
  cpo_session_id                    String? // OCPI ID sent by CPO
  start_date_time                   DateTime?
  end_date_time                     DateTime?
  kwh                               Decimal?     @db.Decimal(10, 3)
  cdr_token                         Json? // OCPICdrToken
  auth_method                       String? // OCPIAuthMethod enum
  authorization_reference           String?      @unique // EMSP session ID
  location_id                       String?
  evse_uid                          String?
  connector_id                      String?
  meter_id                          String?
  currency                          String?
  charging_periods                  Json? // OCPIChargingPeriod[]
  total_cost                        Json? // OCPIPrice
  status                            String? // OCPISessionStatus enum
  last_updated                      DateTime?
  deleted                           Boolean      @default(false)
  deleted_at                        DateTime?
  created_at                        DateTime     @default(now())
  updated_at                        DateTime     @updatedAt
  partner_id                        String?
  partner                           OCPIPartner? @relation(fields: [partner_id], references: [id], onDelete: Cascade)
  requested_energy_units            Decimal?     @db.Decimal(10, 3)
  buyer_info                        Json? // OCPIBusinessDetailsClass
  final_amount                      Json       @default("{}") // Not an OCPI field - internal use only
  additional_props                  Json?      @default("{}") @db.Json // Store if on_update is called for the cdr or not

  // Log relations (named to avoid ambiguity)
  ocpi_logs_session                 OCPILog[]    @relation("OCPILogSession")
  ocpi_logs_cpo_session             OCPILog[]    @relation("OCPILogCpoSession")
  ocpi_logs_authorization_reference OCPILog[]    @relation("OCPILogAuthorizationReferenceSession")

  @@index([country_code, party_id])
  @@index([location_id])
  @@index([status])
  // Optimizes lookups by authorization_reference and CPO session id
  @@index([authorization_reference, partner_id])
  @@index([cpo_session_id, partner_id])
  // Optimizes partner-scoped session listings ordered by last_updated
  @@index([partner_id, last_updated(sort: Desc)])
  @@index([partner_id])
  @@map("session")
}

// OCPI 2.2.1 CDR Model
model CDR {
  id                              String      @id @default(uuid())
  country_code                    String
  party_id                        String
  ocpi_cdr_id                     String // OCPI ID sent by CPO
  start_date_time                 DateTime
  end_date_time                   DateTime
  session_id                      String?
  cdr_token                       Json // OCPICdrToken
  auth_method                     String // OCPIAuthMethod enum
  authorization_reference         String?
  cdr_location                    Json // OCPICdrLocation
  meter_id                        String?
  currency                        String
  tariffs                         Json? // OCPITariff[]
  charging_periods                Json // OCPIChargingPeriod[]
  signed_data                     Json? // OCPISignedData
  total_cost                      Json // OCPIPrice
  total_fixed_cost                Json? // OCPIPrice
  total_energy                    Decimal     @db.Decimal(10, 3)
  total_energy_cost               Json? // OCPIPrice
  total_time                      BigInt
  total_time_cost                 Json? // OCPIPrice
  total_parking_time              BigInt?
  total_parking_cost              Json? // OCPIPrice
  total_reservation_cost          Json? // OCPIPrice
  remark                          String?
  invoice_reference_id            String?
  credit                          Boolean?
  credit_reference_id             String?
  // home_charging_compensation Boolean?
  remarks                         String?
  last_updated                    DateTime
  deleted                         Boolean     @default(false)
  deleted_at                      DateTime?
  created_at                      DateTime    @default(now())
  updated_at                      DateTime    @updatedAt
  partner_id                      String
  partner                         OCPIPartner @relation(fields: [partner_id], references: [id], onDelete: Cascade)
  invoice_details                 Json?       @default("{}") @db.Json

  @@unique([country_code, party_id, ocpi_cdr_id])
  @@index([country_code, party_id])
  @@index([ocpi_cdr_id])
  // Optimizes partner-scoped CDR listings ordered by last_updated
  @@index([partner_id, last_updated(sort: Desc)])
  @@index([partner_id])
  @@map("cdr")
}

// OCPI 2.2.1 Token Model
model Token {
  id                   String      @id @default(uuid())
  country_code         String
  party_id             String
  uid                  String // OCPI ID sent by CPO
  type                 String // OCPITokenType enum
  contract_id          String
  visual_number        String?
  issuer               String
  group_id             String?
  valid                Boolean
  whitelist            String // OCPIWhitelistType enum
  language             String?
  default_profile_type String? // OCPIProfileType enum
  energy_contract      Json? // OCPIEnergyContract
  last_updated         DateTime
  deleted              Boolean     @default(false)
  deleted_at           DateTime?
  created_at           DateTime    @default(now())
  updated_at           DateTime    @updatedAt
  partner_id           String
  partner              OCPIPartner @relation(fields: [partner_id], references: [id], onDelete: Cascade)

  @@unique([country_code, party_id, uid])
  @@index([country_code, party_id])
  @@index([uid])
  // Optimizes partner-scoped token listings ordered by last_updated
  @@index([partner_id, last_updated(sort: Desc)])
  @@index([partner_id])
  @@map("token")
}

// OCPI Partner (CPO) integration metadata
model OCPIPartner {
  id               String                  @id @default(uuid())
  name             String?
  country_code     String
  party_id         String
  role             String                  @default("CPO") // CPO | EMSP
  versions_url     String
  status           String                  @default("INIT")
  credentials      OCPIPartnerCredentials?
  endpoints        OCPIPartnerEndpoint[]
  versions         OCPIVersion[]
  created_at       DateTime                @default(now())
  updated_at       DateTime                @updatedAt
  deleted          Boolean                 @default(false)
  deleted_at       DateTime?
  locations        Location[]
  evses            EVSE[]
  evseconnectors   EVSEConnector[]
  tariffs          Tariff[]
  sessions         Session[]
  cdrs             CDR[]
  tokens           Token[]
  ocpilogs         OCPILog[]
  paymentTxns      PaymentTxn[]
  additional_props Json?                   @default("{}") @db.Json

  @@unique([country_code, party_id])
  // Optimizes lookups of EMSP/CPO by role + deleted flag
  @@index([role, deleted])
  @@map("ocpi_partner")
}

// OCPI credentials exchanged during handshake for a given partner
model OCPIPartnerCredentials {
  id              String      @id @default(uuid())
  partner_id      String      @unique
  partner         OCPIPartner @relation(fields: [partner_id], references: [id], onDelete: Cascade)
  cpo_auth_token  String? // for initial GET /versions, if applicable
  emsp_auth_token String? // token the CPO uses to call this EMSP
  cpo_url         String? // CPO credentials URL
  emsp_url        String? // EMSP credentials URL exposed to CPO
  deleted         Boolean     @default(false)
  deleted_at      DateTime?
  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt

  // Optimizes auth-token based lookups
  @@index([cpo_auth_token])
  @@index([emsp_auth_token])
  @@map("ocpi_partner_credentials")
}

// OCPI endpoints advertised by a partner for a specific version
model OCPIPartnerEndpoint {
  id         String      @id @default(uuid())
  partner_id String
  partner    OCPIPartner @relation(fields: [partner_id], references: [id], onDelete: Cascade)
  version    String // e.g. "2.2.1"
  module     String // e.g. "locations", "tariffs"
  role       String // "SENDER" | "RECEIVER"
  url        String
  deleted    Boolean     @default(false)
  deleted_at DateTime?
  created_at DateTime    @default(now())
  updated_at DateTime    @updatedAt

  // Optimizes endpoint discovery by partner/module/role/version
  @@index([partner_id, module, role, version])
  @@index([partner_id])
  @@map("ocpi_partner_endpoint")
}

model OCPIVersion {
  id          String      @id @default(uuid())
  partner_id  String
  partner     OCPIPartner @relation(fields: [partner_id], references: [id], onDelete: Cascade)
  version_id  String // e.g. "2.2.1"
  version_url String
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt
  deleted     Boolean     @default(false)
  deleted_at  DateTime?

  @@index([partner_id])
  @@map("ocpi_version")
}

/// The model name has to be `UeiLog` because `UEILog` is treated as `uEILog` in the codebase
model BecknLog {
  id               String    @id @default(uuid())
  aiid             BigInt    @default(autoincrement())
  domain           String
  action           String
  transaction_id   String
  message_id       String
  payload          Json?     @default("{}") @db.Json
  additional_props Json?     @default("{}") @db.Json /// Added for any future requirements
  created_on       DateTime  @default(now())
  updated_on       DateTime  @updatedAt
  deleted          Boolean?  @default(false)
  deleted_on       DateTime?

  @@index([domain])
  @@index([action])
  @@index([transaction_id])
  @@index([message_id])
  @@index([domain, action, transaction_id, created_on(sort: Desc)])
  @@index([created_on(sort: Desc)])
  @@map(name: "beckn_log")
}

model OCPILog {
  id                              String         @id @default(uuid())
  aiid                            BigInt         @default(autoincrement())
  command                         String // OCPILogCommand enum
  sender_type                     String // CPO | EMSP
  url                             String
  payload                         Json           @db.Json
  additional_props                Json?          @default("{}") @db.Json
  partner_id                      String
  partner                         OCPIPartner    @relation(fields: [partner_id], references: [id], onDelete: Cascade)
  location_id                     String?
  location                        Location?      @relation(fields: [location_id], references: [id], onDelete: Cascade)
  evse_id                         String?
  evse                            EVSE?          @relation(fields: [evse_id], references: [id], onDelete: Cascade)
  connector_id                    String?
  connector                       EVSEConnector? @relation(fields: [connector_id], references: [id], onDelete: Cascade)
  session_id                      String?
  session                         Session?       @relation("OCPILogSession", fields: [session_id], references: [id], onDelete: Cascade)
  authorization_reference         String?
  authorization_reference_session Session?       @relation("OCPILogAuthorizationReferenceSession", fields: [authorization_reference], references: [id], onDelete: Cascade)
  cpo_session_id                  String?
  cpo_session                     Session?       @relation("OCPILogCpoSession", fields: [cpo_session_id], references: [id], onDelete: Cascade)
  created_on                      DateTime       @default(now())

  // Optimizes log exploration by partner and time
  @@index([partner_id, created_on(sort: Desc)])
  @@index([command])
  @@index([sender_type])
  @@map(name: "ocpi_log")
}

model PaymentTxn {
  id                              String      @id @default(uuid())
  authorization_reference         String      
  amount                          Decimal     @db.Decimal(10, 2)
  payment_link                    String?
  payment_breakdown               Json        @default("{}") @db.Json
  status                          String
  requested_energy_units          Decimal     @db.Decimal(10, 3)
  partner_id                      String
  partner                         OCPIPartner @relation(fields: [partner_id], references: [id], onDelete: Cascade)
  beckn_transaction_id            String
  payment_gateway_order_id        String?     // BillDesk/Razorpay order ID
  payment_gateway_payment_id      String?     // BillDesk/Razorpay payment/transaction ID
  details                         Json?       @default("{}") @db.Json // Full payment gateway response
  additional_props                Json?       @default("{}") @db.Json
  beneficiary                     String?     // 'BAP' or 'BPP'
  created_at                      DateTime    @default(now())
  updated_at                      DateTime    @updatedAt
  deleted                         Boolean     @default(false)
  deleted_at                      DateTime?
  service_charge                  Json       @default("{}") @db.Json // {"buyer_finder_fee": 0.9, "network_fee": 0.3} // in percentage

  @@index([authorization_reference])
  @@index([partner_id])
  @@index([payment_gateway_order_id])
  @@map("payment_txn")
}

model RatingRecord {
  id                    String   @id @default(uuid())
  beckn_transaction_id  String
  message_id            String
  bpp_id                String?
  bpp_uri               String?
  bap_id                String?
  bap_uri               String?
  rating_value          Decimal  @db.Decimal(5, 2)
  rating_category       String
  best_rating           Decimal? @db.Decimal(5, 2)
  worst_rating          Decimal? @db.Decimal(5, 2)
  auth_reference        String?
  comments              String?
  tags                  Json?    @default("[]") @db.Json
  partner_id            String?
  session_id            String?
  payment_txn_id        String?
  backend_url           String?
  backend_request       Json?    @default("{}") @db.Json
  backend_response      Json?    @default("{}") @db.Json
  on_rating_payload     Json?    @default("{}") @db.Json
  status                String   @default("RECEIVED")
  error_message         String?
  additional_props      Json?    @default("{}") @db.Json
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  @@index([beckn_transaction_id])
  @@index([message_id])
  @@index([partner_id])
  @@index([session_id])
  @@index([payment_txn_id])
  @@index([status])
  @@map("rating_record")
}
